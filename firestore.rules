rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email == "stokie2605@gmail.com";
    }

    function profileRoleIn(roles) {
      return isAdmin()
        || (
          isSignedIn()
          && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
          && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role in roles
        );
    }

    function canOperateOrders() {
      return profileRoleIn(["volunteer", "admin"]);
    }

    function isOwnPartnerProfileCreate(userId) {
      return isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          "email",
          "name",
          "role"
        ])
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.role == "partner";
    }

    function isLiveOrderCreate() {
      return profileRoleIn(["partner", "admin"])
        && request.resource.data.keys().hasOnly([
          "agencyName",
          "recipientName",
          "recipientPhone",
          "targetCollectionTime",
          "familySize",
          "dietaryNotes",
          "status",
          "submittedBy",
          "createdAt",
          "completedAt"
        ])
        && request.resource.data.agencyName is string
        && request.resource.data.agencyName.size() > 0
        && request.resource.data.recipientName is string
        && request.resource.data.recipientName.size() > 0
        && request.resource.data.recipientPhone is string
        && request.resource.data.recipientPhone.size() > 0
        && request.resource.data.targetCollectionTime is string
        && request.resource.data.targetCollectionTime.size() > 0
        && request.resource.data.familySize is int
        && request.resource.data.familySize >= 1
        && request.resource.data.dietaryNotes is string
        && request.resource.data.status == "New"
        && request.resource.data.submittedBy == request.auth.uid;
    }

    function isLiveOrderPackUpdate() {
      return canOperateOrders()
        && resource.data.status == "New"
        && request.resource.data.status == "Ready for Collection"
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "status",
          "updatedAt",
          "updatedBy"
        ])
        && request.resource.data.updatedBy == request.auth.uid;
    }

    function isLiveOrderCompleteUpdate() {
      return canOperateOrders()
        && resource.data.status == "Ready for Collection"
        && request.resource.data.status == "archived"
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "status",
          "updatedAt",
          "updatedBy",
          "completedAt",
          "completedBy"
        ])
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.completedBy == request.auth.uid;
    }

    function isLiveOrderTypoUpdate() {
      return (
          canOperateOrders()
          || (
            profileRoleIn(["partner"])
            && resource.data.submittedBy == request.auth.uid
          )
        )
        && resource.data.status in ["New", "Ready for Collection"]
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "recipientName",
          "recipientPhone",
          "targetCollectionTime",
          "dietaryNotes",
          "updatedAt",
          "updatedBy"
        ])
        && request.resource.data.recipientName is string
        && request.resource.data.recipientName.size() > 0
        && request.resource.data.recipientPhone is string
        && request.resource.data.recipientPhone.size() > 0
        && request.resource.data.targetCollectionTime is string
        && request.resource.data.targetCollectionTime.size() > 0
        && request.resource.data.dietaryNotes is string
        && request.resource.data.updatedBy == request.auth.uid;
    }

    function isPublicStatusWrite() {
      return profileRoleIn(["partner", "volunteer", "admin"])
        && request.resource.data.keys().hasOnly([
          "recipientName",
          "targetCollectionTime",
          "status",
          "updatedAt"
        ])
        && request.resource.data.recipientName is string
        && request.resource.data.targetCollectionTime is string
        && request.resource.data.status in ["New", "Ready for Collection", "archived"];
    }

    function isNotificationEventCreate() {
      return profileRoleIn(["partner", "volunteer", "admin"])
        && request.resource.data.keys().hasOnly([
          "orderId",
          "recipientPhone",
          "recipientName",
          "status",
          "channel",
          "message",
          "webhookConfigured",
          "webhookSent",
          "webhookError",
          "createdAt"
        ])
        && request.resource.data.recipientPhone is string
        && request.resource.data.recipientPhone.size() > 0
        && request.resource.data.recipientName is string
        && request.resource.data.status in ["New", "Ready for Collection", "archived"]
        && request.resource.data.channel == "sms"
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.webhookConfigured is bool
        && request.resource.data.webhookSent is bool
        && request.resource.data.webhookError is string;
    }

    match /profiles/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin() || isOwnPartnerProfileCreate(userId);
      allow update, delete: if isAdmin();
    }

    match /live_orders/{orderId} {
      allow read: if profileRoleIn(["partner", "volunteer", "admin"]);
      allow create: if isLiveOrderCreate();
      allow update: if isAdmin() || isLiveOrderPackUpdate() || isLiveOrderCompleteUpdate() || isLiveOrderTypoUpdate();
      allow delete: if isAdmin();
    }

    match /public_status/{phoneKey} {
      allow get: if true;
      allow list: if false;
      allow create, update: if isPublicStatusWrite();
      allow delete: if isAdmin();
    }

    match /notification_events/{eventId} {
      allow read: if isAdmin();
      allow create: if isNotificationEventCreate();
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
