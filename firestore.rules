rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function currentUserDoc() {
      return get(userPath(request.auth.uid));
    }

    function currentRole() {
      return signedIn() && exists(userPath(request.auth.uid))
        ? currentUserDoc().data.role
        : null;
    }

    function isAdmin() {
      return currentRole() == "admin";
    }

    function isActiveVolunteer() {
      return currentRole() == "active_volunteer";
    }

    function isPartner() {
      return currentRole() == "partner";
    }

    function isDemoVolunteer() {
      return currentRole() == "demo_volunteer" && currentAgencyId() == "demo-agency";
    }

    function currentAgencyId() {
      return signedIn() && exists(userPath(request.auth.uid))
        ? currentUserDoc().data.agencyId
        : null;
    }

    function validRole(role) {
      return role in ["pending", "partner", "active_volunteer", "admin", "demo_volunteer"];
    }

    function validUserProfile(data) {
      return data.keys().hasOnly([
        "uid",
        "email",
        "displayName",
        "photoURL",
        "role",
        "agencyId",
        "agencyName",
        "requestedAgencyName",
        "createdAt",
        "updatedAt",
        "name",
        "organization_name",
        "id"
      ])
      && data.uid is string
      && data.role is string
      && validRole(data.role)
      && (!("agencyId" in data) || data.agencyId == null || data.agencyId is string)
      && (!("agencyName" in data) || data.agencyName == null || data.agencyName is string)
      && (!("requestedAgencyName" in data) || data.requestedAgencyName == null || data.requestedAgencyName is string)
      && (!("email" in data) || data.email == null || data.email is string)
      && (!("displayName" in data) || data.displayName == null || data.displayName is string)
      && (!("name" in data) || data.name == null || data.name is string)
      && (!("organization_name" in data) || data.organization_name == null || data.organization_name is string)
      && (!("id" in data) || data.id == null || data.id is string)
      && (!("photoURL" in data) || data.photoURL == null || data.photoURL is string);
    }

    function roleWasNotChanged() {
      return !request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasAny(["role", "agencyId", "agencyName", "requestedAgencyName"]);
    }

    match /users/{userId} {
      allow create: if signedIn()
        && request.auth.uid == userId
        && validUserProfile(request.resource.data)
        && request.resource.data.uid == userId
        && request.resource.data.role == "pending";

      allow read: if signedIn()
        && (
          request.auth.uid == userId ||
          isAdmin()
        );

      allow update: if signedIn()
        && request.resource.data.uid == userId
        && (
          isAdmin() ||
          (
            validUserProfile(request.resource.data) &&
            request.auth.uid == userId &&
            roleWasNotChanged()
          )
        );

      allow delete: if isAdmin();
    }

    function validOrderStatus(status) {
      return status in ["New", "Accepted", "Ready for Collection", "archived"];
    }

    function validTimestampOrNull(data, field) {
      return !(field in data) || data[field] == null || data[field] is timestamp;
    }

    function validLiveOrder(data) {
      return data.keys().hasOnly([
        "agencyId",
        "agencyName",
        "recipientName",
        "recipientPhone",
        "recipientEmail",
        "targetCollectionTime",
        "familySize",
        "dietaryNotes",
        "status",
        "submittedBy",
        "createdAt",
        "acceptedAt",
        "readyAt",
        "collectedAt",
        "completedAt",
        "completedBy",
        "updatedAt",
        "updatedBy",
        "anonymizedAt"
      ])
      && data.agencyId is string
      && data.agencyName is string
      && data.recipientName is string
      && data.recipientPhone is string
      && (!("recipientEmail" in data) || data.recipientEmail is string)
      && data.targetCollectionTime is string
      && data.familySize is number
      && data.familySize >= 0
      && data.dietaryNotes is string
      && data.status is string
      && validOrderStatus(data.status)
      && data.submittedBy is string
      && validTimestampOrNull(data, "createdAt")
      && validTimestampOrNull(data, "acceptedAt")
      && validTimestampOrNull(data, "readyAt")
      && validTimestampOrNull(data, "collectedAt")
      && validTimestampOrNull(data, "completedAt")
      && validTimestampOrNull(data, "updatedAt")
      && validTimestampOrNull(data, "anonymizedAt")
      && (!("updatedBy" in data) || data.updatedBy is string)
      && (!("completedBy" in data) || data.completedBy is string);
    }

    function orderOwnershipWasNotChanged() {
      return request.resource.data.submittedBy == resource.data.submittedBy
        && request.resource.data.agencyId == resource.data.agencyId
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function validStatusTransition(fromStatus, toStatus) {
      return fromStatus == toStatus
        || (fromStatus == "New" && toStatus == "Accepted")
        || (fromStatus == "Accepted" && toStatus == "Ready for Collection")
        || (fromStatus == "Ready for Collection" && toStatus == "archived");
    }

    function partnerCanUpdateOwnNewOrder() {
      return isPartner()
        && resource.data.agencyId == currentAgencyId()
        && resource.data.submittedBy == request.auth.uid
        && resource.data.status == "New"
        && request.resource.data.status == resource.data.status;
    }

    match /live_orders/{orderId} {
      allow read: if isActiveVolunteer() || isAdmin() || (isPartner() && resource.data.agencyId == currentAgencyId()) || (isDemoVolunteer() && resource.data.agencyId == "demo-agency");
      allow create: if validLiveOrder(request.resource.data)
        && request.resource.data.status == "New"
        && (
          isActiveVolunteer() ||
          isAdmin() ||
          (
            isPartner()
            && request.resource.data.agencyId == currentAgencyId()
            && request.resource.data.submittedBy == request.auth.uid
          ) ||
          (
            isDemoVolunteer()
            && request.resource.data.agencyId == "demo-agency"
          )
        );
      allow update: if validLiveOrder(request.resource.data)
        && orderOwnershipWasNotChanged()
        && validStatusTransition(resource.data.status, request.resource.data.status)
        && (
          isActiveVolunteer() ||
          isAdmin() ||
          partnerCanUpdateOwnNewOrder() ||
          (
            isDemoVolunteer()
            && resource.data.agencyId == "demo-agency"
            && request.resource.data.agencyId == "demo-agency"
          )
        );
      allow delete: if isAdmin();
    }

    match /agencies/{agencyId} {
      allow read: if isAdmin() || isActiveVolunteer() || isPartner() || (isDemoVolunteer() && agencyId == "demo-agency");
      allow create, update, delete: if isAdmin();
    }


    match /config/noticeboard {
      allow read: if isAdmin() || isActiveVolunteer() || isPartner() || isDemoVolunteer();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /handover_notes/{noteId} {
      allow read, create: if isAdmin() || isActiveVolunteer();
      allow update, delete: if isAdmin();
    }

    match /support_links/{linkId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /public_status/{phoneKey} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isActiveVolunteer() || isAdmin() || isPartner() || isDemoVolunteer();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

