rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email == "stokie2605@gmail.com";
    }

    function hasModeratorAccess() {
      return isAdmin()
        || (
          isSignedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "moderator", "mod"]
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
          )
        );
    }

    function hasFoodbankStaffAccess() {
      return isAdmin()
        || (
          isSignedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "moderator", "mod", "volunteer"]
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isVolunteer == true
          )
        );
    }

    function hasPartnerReferralAccess() {
      return hasFoodbankStaffAccess()
        || (
          isSignedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["partner"]
        );
    }

    function isKnownCollectionPoint(pointId) {
      return pointId in [
        "sainsburys_local_bin",
        "asda_cage",
        "church_cabinet",
        "main_hub_drop_off"
      ];
    }

    function hasValidCollectionPointCreatePayload(pointId) {
      return isSignedIn()
        && isKnownCollectionPoint(pointId)
        && request.resource.data.keys().hasOnly([
          "status",
          "priority",
          "updated_at",
          "reported_at",
          "collected_at"
        ])
        && request.resource.data.status in ["clear", "full"]
        && request.resource.data.priority in [0, 1]
        && request.resource.data.updated_at is string
        && request.resource.data.updated_at.size() > 0;
    }

    function isCollectionPointStatusUpdate(pointId) {
      return isSignedIn()
        && isKnownCollectionPoint(pointId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "status",
          "priority",
          "updated_at",
          "reported_at",
          "collected_at"
        ])
        && request.resource.data.status in ["clear", "full"]
        && request.resource.data.priority in [0, 1]
        && request.resource.data.updated_at is string
        && request.resource.data.updated_at.size() > 0;
    }

    function hasValidCollectionPointAdminTextPayload(pointId) {
      return hasModeratorAccess()
        && isKnownCollectionPoint(pointId)
        && request.resource.data.keys().hasOnly([
          "name",
          "address",
          "notes",
          "updated_at"
        ])
        && request.resource.data.updated_at is string
        && request.resource.data.updated_at.size() > 0;
    }

    function isCollectionPointAdminTextUpdate(pointId) {
      return hasModeratorAccess()
        && isKnownCollectionPoint(pointId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "name",
          "address",
          "notes",
          "updated_at"
        ])
        && request.resource.data.updated_at is string
        && request.resource.data.updated_at.size() > 0;
    }

    function isDonationBulletinWrite(settingId) {
      return isAdmin()
        && settingId == "bulletin"
        && request.resource.data.keys().hasOnly([
          "text",
          "updated_at",
          "updated_by"
        ])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.updated_at is string
        && request.resource.data.updated_at.size() > 0;
    }

    function existingVerifiedCount() {
      return "verifiedCount" in resource.data && resource.data.verifiedCount is int
        ? resource.data.verifiedCount
        : 0;
    }

    function existingRepliesCount() {
      return "replies" in resource.data && resource.data.replies is list
        ? resource.data.replies.size()
        : 0;
    }


    function isOwnClientProfileCreate(userId) {
      return isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == "client"
        && request.resource.data.isAdmin == false
        && request.resource.data.isVolunteer == false;
    }
    function isOwnPostCreate() {
      return isSignedIn()
        && request.resource.data.donor_id == request.auth.uid;
    }

    function isAuthenticatedClaimUpdate() {
      return isSignedIn()
        && resource.data.status == "available"
        && request.resource.data.status == "claimed"
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "status",
          "receiver_id",
          "claimed_at"
        ])
        && request.resource.data.diff(resource.data).changedKeys().hasAll([
          "status",
          "receiver_id",
          "claimed_at"
        ])
        && request.resource.data.receiver_id == request.auth.uid
        && request.resource.data.claimed_at is string
        && request.resource.data.claimed_at.size() > 0;
    }

    function isAuthenticatedCompletionUpdate() {
      return isSignedIn()
        && resource.data.status == "claimed"
        && resource.data.receiver_id == request.auth.uid
        && request.resource.data.status == "completed"
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "status",
          "completed_at"
        ])
        && request.resource.data.diff(resource.data).changedKeys().hasAll([
          "status",
          "completed_at"
        ])
        && request.resource.data.completed_at is string
        && request.resource.data.completed_at.size() > 0;
    }

    function isAuthenticatedVerificationUpdate() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "verifiedCount",
          "verified_at"
        ])
        && request.resource.data.diff(resource.data).changedKeys().hasAll([
          "verifiedCount",
          "verified_at"
        ])
        && request.resource.data.verifiedCount == existingVerifiedCount() + 1
        && request.resource.data.verified_at is string
        && request.resource.data.verified_at.size() > 0;
    }

    function isModeratorArchiveUpdate() {
      return hasModeratorAccess()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "archived",
          "archived_by",
          "archived_at"
        ])
        && request.resource.data.diff(resource.data).changedKeys().hasAll([
          "archived",
          "archived_by",
          "archived_at"
        ])
        && request.resource.data.archived == true
        && request.resource.data.archived_by == request.auth.uid
        && request.resource.data.archived_at is string
        && request.resource.data.archived_at.size() > 0;
    }

    function isAuthenticatedReplyUpdate() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["replies"])
        && request.resource.data.replies is list
        && request.resource.data.replies.size() == existingRepliesCount() + 1;
    }

    function isReferralWorkflowStart() {
      return hasPartnerReferralAccess()
        && resource.data.status == "Pending Contact"
        && request.resource.data.status == "Building"
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "status",
          "workflow_started_at",
          "workflow_started_by"
        ])
        && request.resource.data.workflow_started_by == request.auth.uid
        && request.resource.data.workflow_started_at is string
        && request.resource.data.workflow_started_at.size() > 0;
    }

    function isVoucherWorkflowStart() {
      return hasFoodbankStaffAccess()
        && resource.data.status in ["Pending Contact", "pending"]
        && request.resource.data.status == "Building"
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "status",
          "workflow_started_at",
          "workflow_started_by"
        ])
        && request.resource.data.workflow_started_by == request.auth.uid
        && request.resource.data.workflow_started_at is string
        && request.resource.data.workflow_started_at.size() > 0;
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isOwnPostCreate();
      allow update: if isAdmin()
        || isAuthenticatedClaimUpdate()
        || isAuthenticatedCompletionUpdate()
        || isAuthenticatedVerificationUpdate()
        || isModeratorArchiveUpdate()
        || isAuthenticatedReplyUpdate();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin() || isOwnClientProfileCreate(userId);
      allow update, delete: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /intakes/{intakeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /referral_vouchers/{voucherId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isVoucherWorkflowStart();
    }

    match /donations_receipts/{receiptId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /donation_collection_points/{pointId} {
      allow read: if true;
      allow create: if hasValidCollectionPointCreatePayload(pointId) || hasValidCollectionPointAdminTextPayload(pointId);
      allow update: if isCollectionPointStatusUpdate(pointId) || isCollectionPointAdminTextUpdate(pointId);
      allow delete: if isAdmin();
    }

    match /donation_logs/{logId} {
      allow read: if hasFoodbankStaffAccess();
      allow create: if hasFoodbankStaffAccess();
      allow update, delete: if isAdmin();
    }

    match /referrals/{referralId} {
      allow read: if hasPartnerReferralAccess();
      allow create: if hasPartnerReferralAccess()
        && request.resource.data.keys().hasOnly([
          "agency_name",
          "client_reference",
          "family_size",
          "dietary_requirements",
          "urgency",
          "status",
          "submitted_by",
          "created_at"
        ])
        && request.resource.data.agency_name is string
        && request.resource.data.agency_name.size() > 0
        && request.resource.data.client_reference is string
        && request.resource.data.client_reference.size() > 0
        && request.resource.data.family_size is int
        && request.resource.data.family_size >= 1
        && request.resource.data.urgency in ["Low", "Medium", "High"]
        && request.resource.data.status == "Pending Contact"
        && request.resource.data.submitted_by == request.auth.uid;
      allow update: if isAdmin() || isReferralWorkflowStart();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if settingId == "bulletin";
      allow create, update: if isDonationBulletinWrite(settingId);
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
